# audaza-links — redirector universal
# Vale para:
#   - audaza.com/l/{slug}, /g/{slug}, /b/{slug}    (path-based)
#   - link.audaza.com/{slug}, go.audaza.com/{slug}, bio.audaza.com/{slug}
#
# Comportamento: se a URL bater com arquivo OU pasta existente, serve normal
# (importante p/ bio.audaza.com não atrapalhar biolinks publicados).
# Caso contrário, manda pra index.php que consulta o Supabase.

Options -MultiViews -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Não rescreve files/folders existentes
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Tudo o resto vai pro index.php (relativo ao diretório onde mora o .htaccess)
  RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Bloqueia leitura direta do config
<Files "config.php">
  Require all denied
</Files>
<Files "config.example.php">
  Require all denied
</Files>

# Headers de segurança básica
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
